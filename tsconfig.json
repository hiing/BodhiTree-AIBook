{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "types": ["vitepress/client"]
  },
  "include": ["docs/.vitepress/**/*.ts", "scripts/**/*.mjs"],
  "exclude": ["node_modules", "docs/.vitepress/dist"]
}
